      "minArgs": 1,
      "maxArgs": 1,
      "argTypes": [
        "number"
      ]
    },
    "ge": {
      "description": "以上か",
      "hasArgs": true,
      "resultType": "boolean",
      "acceptTypes": [
        "number",
        "string"
      ],
      "minArgs": 1,
      "maxArgs": 1,
      "argTypes": [
        "number"
      ]
    },
    "inc": {
      "description": "加算",
      "hasArgs": true,
      "resultType": "number",
      "acceptTypes": [
        "number"
      ],
      "minArgs": 0,
      "maxArgs": 1,
      "argTypes": [
        "number"
      ]
