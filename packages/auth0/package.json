{
  "name": "@wcstack/auth0",
  "version": "0.1.0",
  "description": "Declarative Auth0 authentication component for Web Components. Framework-agnostic auth via wc-bindable-protocol.",
  "type": "module",
  "main": "./dist/index.esm.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js"
    },
    "./auto": "./dist/auto.min.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist .tsc-out",
    "build": "rimraf dist .tsc-out && tsc && rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "prepublishOnly": "npm run build && npm run test:coverage"
  },
  "keywords": [
    "web-components",
    "auth0",
    "authentication",
    "custom-elements",
    "wc-bindable",
    "declarative",
    "zero-dependencies",
    "framework-agnostic"
  ],
  "author": "mogera551",
  "homepage": "https://wcstack.github.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/wcstack/wcstack.git",
    "directory": "packages/auth0"
  },
  "bugs": {
    "url": "https://github.com/wcstack/wcstack/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "@auth0/auth0-spa-js": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@auth0/auth0-spa-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@auth0/auth0-spa-js": "^2.1.3",
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.11",
    "rimraf": "^6.0.1",
    "rollup": "^4.22.4",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-copy": "^3.5.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.15"
  }
}
