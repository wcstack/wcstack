{
  "name": "@wcstack/signals",
  "version": "1.16.0",
  "description": "Signals-based lightweight reactive core with async-IO resource adapters and a wc-bindable → signal bridge for Web Components. Zero runtime dependencies.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.esm.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js"
    },
    "./dom": {
      "types": "./dist/dom.d.ts",
      "import": "./dist/dom.esm.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist .tsc-out",
    "build": "rimraf dist .tsc-out && tsc && rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "size": "size-limit",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint src"
  },
  "keywords": [
    "web-components",
    "signals",
    "reactive",
    "state-management",
    "wc-bindable",
    "zero-dependencies",
    "framework-agnostic"
  ],
  "author": "mogera551",
  "homepage": "https://wcstack.github.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/wcstack/wcstack.git",
    "directory": "packages/signals"
  },
  "bugs": {
    "url": "https://github.com/wcstack/wcstack/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.39.1",
    "fast-check": "^4.8.0",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.11",
    "rimraf": "^6.0.1",
    "rollup": "^4.22.4",
    "rollup-plugin-dts": "^6.1.1",
    "size-limit": "^12.1.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.15"
  }
}
